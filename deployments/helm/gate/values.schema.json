{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "GATE: Helm Values",
  "description": "Configuration schema for the Helm chart of GATE (GitHub Authenticated Token Exchange)",
  "required": [
    "config"
  ],
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full resource name (takes precedence over nameOverride)"
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "properties": {
        "registry": {
          "type": "string",
          "description": "Container registry (optional, omit for Docker Hub)"
        },
        "repository": {
          "type": "string",
          "description": "Image repository name"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "description": "Image pull policy"
        },
        "tag": {
          "type": "string",
          "description": "Image tag (defaults to Chart.appVersion)"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Pull secrets for private container registries",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a ServiceAccount for the pods"
        },
        "automount": {
          "type": "boolean",
          "description": "Automatically mount the ServiceAccount token"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the ServiceAccount",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "description": "ServiceAccount name (auto-generated if empty and create=true)"
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of pod replicas (ignored if autoscaling.enabled=true)"
    },
    "podAnnotations": {
      "type": "object",
      "description": "Annotations to add to pods",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podLabels": {
      "type": "object",
      "description": "Labels to add to pods (in addition to selector labels)",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context (applied to all containers)",
      "properties": {
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "fsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "RuntimeDefault",
                "Localhost",
                "Unconfined"
              ]
            },
            "localhostProfile": {
              "type": "string"
            }
          }
        },
        "fsGroupChangePolicy": {
          "type": "string",
          "enum": [
            "OnRootMismatch",
            "Always"
          ]
        },
        "supplementalGroups": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context",
      "properties": {
        "allowPrivilegeEscalation": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "add": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "drop": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "readOnlyRootFilesystem": {
          "type": "boolean"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "privileged": {
          "type": "boolean"
        },
        "procMount": {
          "type": "string",
          "enum": [
            "Default",
            "Unmasked"
          ]
        },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "RuntimeDefault",
                "Localhost",
                "Unconfined"
              ]
            },
            "localhostProfile": {
              "type": "string"
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU/memory resource requests and limits",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^([0-9]+m?|[0-9]+\\.[0-9]+)$",
              "description": "CPU limit (e.g., 500m, 1, 1.5)"
            },
            "memory": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|K|M|G|T|P|E|e[0-9]+)?$",
              "description": "Memory limit (e.g., 128Mi, 1Gi)"
            }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^([0-9]+m?|[0-9]+\\.[0-9]+)$",
              "description": "CPU request (e.g., 100m, 0.5)"
            },
            "memory": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|K|M|G|T|P|E|e[0-9]+)?$",
              "description": "Memory request (e.g., 64Mi, 256Mi)"
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "description": "Horizontal Pod Autoscaler configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable HPA"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of replicas"
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of replicas"
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Target CPU utilization percentage"
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Target memory utilization percentage"
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "description": "Pod Disruption Budget configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable PDB"
        },
        "minAvailable": {
          "type": [
            "integer",
            "string"
          ],
          "description": "Minimum available pods (number or percentage)"
        },
        "maxUnavailable": {
          "type": [
            "integer",
            "string"
          ],
          "description": "Maximum unavailable pods (number or percentage)"
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "operator": {
            "type": "string",
            "enum": [
              "Exists",
              "Equal"
            ]
          },
          "value": {
            "type": "string"
          },
          "effect": {
            "type": "string",
            "enum": [
              "NoSchedule",
              "PreferNoSchedule",
              "NoExecute"
            ]
          },
          "tolerationSeconds": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod scheduling",
      "properties": {
        "nodeAffinity": {
          "type": "object"
        },
        "podAffinity": {
          "type": "object"
        },
        "podAntiAffinity": {
          "type": "object"
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Kubernetes Service configuration",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ],
          "description": "Service type"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Service port (external)"
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Target port (container port)"
        },
        "nodePort": {
          "type": "integer",
          "minimum": 30000,
          "maximum": 32767,
          "description": "Node port (only for NodePort/LoadBalancer types)"
        },
        "annotations": {
          "type": "object",
          "description": "Service annotations",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Ingress"
        },
        "className": {
          "type": "string",
          "description": "Ingress class name (e.g., nginx, alb, traefik)"
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts configuration",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "description": "Hostname"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "path",
                    "pathType"
                  ],
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string",
                      "enum": [
                        "Prefix",
                        "Exact",
                        "ImplementationSpecific"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "description": "TLS configuration",
          "items": {
            "type": "object",
            "properties": {
              "secretName": {
                "type": "string"
              },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "description": "Network Policy configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable NetworkPolicy"
        },
        "policyTypes": {
          "type": "array",
          "description": "Policy types to enforce",
          "items": {
            "type": "string",
            "enum": [
              "Ingress",
              "Egress"
            ]
          }
        },
        "ingress": {
          "type": "array",
          "description": "Ingress rules"
        },
        "egress": {
          "type": "array",
          "description": "Egress rules"
        }
      }
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration",
      "properties": {
        "httpGet": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "port": {
              "type": [
                "integer",
                "string"
              ]
            },
            "scheme": {
              "type": "string",
              "enum": [
                "HTTP",
                "HTTPS"
              ]
            },
            "httpHeaders": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tcpSocket": {
          "type": "object",
          "properties": {
            "port": {
              "type": [
                "integer",
                "string"
              ]
            }
          }
        },
        "exec": {
          "type": "object",
          "properties": {
            "command": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds before first probe"
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds between probes"
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Probe timeout"
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Failures before marking unhealthy"
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Successes before marking healthy"
        }
      }
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration",
      "properties": {
        "httpGet": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "port": {
              "type": [
                "integer",
                "string"
              ]
            },
            "scheme": {
              "type": "string",
              "enum": [
                "HTTP",
                "HTTPS"
              ]
            },
            "httpHeaders": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tcpSocket": {
          "type": "object",
          "properties": {
            "port": {
              "type": [
                "integer",
                "string"
              ]
            }
          }
        },
        "exec": {
          "type": "object",
          "properties": {
            "command": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds before first probe"
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds between probes"
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Probe timeout"
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Failures before marking not ready"
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Successes before marking ready"
        }
      }
    },
    "config": {
      "type": "object",
      "description": "Application configuration",
      "required": [
        "policy",
        "oidc"
      ],
      "properties": {
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Application log level"
        },
        "logFormat": {
          "type": "string",
          "enum": [
            "json",
            "text"
          ],
          "description": "Log output format"
        },
        "server": {
          "type": "object",
          "description": "HTTP server configuration",
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "description": "HTTP server port"
            },
            "readTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "HTTP read timeout (e.g., 30s, 1m)"
            },
            "writeTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "HTTP write timeout (e.g., 30s, 1m)"
            },
            "shutdownTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Graceful shutdown timeout (e.g., 10s)"
            },
            "requestTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Per-request timeout (e.g., 30s)"
            },
            "idleTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Idle connection timeout (e.g., 10s)"
            },
            "waitTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Wait timeout for graceful connection draining (e.g., 10s)"
            },
            "tls": {
              "type": "object",
              "description": "TLS configuration for direct TLS termination at the application (optional)",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable direct TLS termination at the application"
                },
                "secretName": {
                  "type": "string",
                  "description": "Kubernetes Secret containing tls.crt and tls.key"
                },
                "certFilePath": {
                  "type": "string",
                  "description": "Path to TLS certificate file inside the container"
                },
                "keyFilePath": {
                  "type": "string",
                  "description": "Path to TLS private key file inside the container"
                }
              }
            }
          }
        },
        "fips": {
          "type": "object",
          "description": "FIPS 140-3 compliance configuration for FedRAMP and regulated environments",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable FIPS 140-3 mode (requires FIPS-compiled binary)"
            },
            "mode": {
              "type": "string",
              "enum": [
                "on",
                "only"
              ],
              "description": "FIPS mode: 'on' enables FIPS algorithms, 'only' additionally rejects non-FIPS algorithms"
            }
          }
        },
        "oidc": {
          "type": "object",
          "description": "OIDC validation configuration",
          "required": [
            "audience"
          ],
          "properties": {
            "audience": {
              "type": "string",
              "minLength": 1,
              "description": "Expected OIDC audience claim"
            }
          }
        },
        "githubApps": {
          "type": "object",
          "description": "GitHub Apps credentials",
          "required": [
            "apps"
          ],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": [
                "kubernetesSecret",
                "externalSecret"
              ],
              "description": "Secret management strategy"
            },
            "apps": {
              "type": "array",
              "description": "GitHub Apps metadata. Private keys mounted from secret at /secrets/github-apps/app-N.pem",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "clientId",
                  "organization"
                ],
                "properties": {
                  "clientId": {
                    "type": "string",
                    "pattern": "^Iv[0-9a-zA-Z]{16,}$",
                    "description": "GitHub App client ID (starts with Iv)"
                  },
                  "organization": {
                    "type": "string",
                    "minLength": 1,
                    "description": "GitHub organization or user name"
                  }
                }
              }
            },
            "kubernetesSecret": {
              "type": "object",
              "description": "Kubernetes Secret reference (when strategy=kubernetesSecret)",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Secret name"
                }
              }
            },
            "externalSecret": {
              "type": "object",
              "description": "External Secrets configuration (when strategy=externalSecret)",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "secretStoreName": {
                  "type": "string",
                  "description": "SecretStore name to reference"
                },
                "remoteSecretName": {
                  "type": "string",
                  "description": "Remote secret name"
                },
                "refreshInterval": {
                  "type": "string",
                  "pattern": "^[0-9]+(s|m|h)$",
                  "description": "Secret refresh interval"
                }
              }
            }
          }
        },
        "originVerification": {
          "type": "object",
          "description": "Origin verification configuration (e.g., CloudFront shared secret)",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable origin verification header validation"
            },
            "headerName": {
              "type": "string",
              "description": "Header name that the reverse proxy sends and the application validates"
            },
            "strategy": {
              "type": "string",
              "enum": [
                "kubernetesSecret",
                "externalSecret"
              ],
              "description": "Secret management strategy for the verification value"
            },
            "kubernetesSecret": {
              "type": "object",
              "description": "Kubernetes Secret reference (when strategy=kubernetesSecret)",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Secret name"
                },
                "key": {
                  "type": "string",
                  "description": "Key within the Secret"
                }
              }
            },
            "externalSecret": {
              "type": "object",
              "description": "External Secrets configuration (when strategy=externalSecret)",
              "properties": {
                "secretStoreName": {
                  "type": "string",
                  "description": "SecretStore name to reference"
                },
                "remoteSecretName": {
                  "type": "string",
                  "description": "Remote secret name in Secrets Manager"
                },
                "refreshInterval": {
                  "type": "string",
                  "pattern": "^[0-9]+(s|m|h)$",
                  "description": "Secret refresh interval"
                }
              }
            }
          }
        },
        "awsRegion": {
          "type": "string",
          "description": "AWS region for DynamoDB backends"
        },
        "audit": {
          "type": "object",
          "description": "Audit logging configuration",
          "properties": {
            "backend": {
              "type": "string",
              "enum": [
                "",
                "sql",
                "dynamodb"
              ],
              "description": "Audit backend type (empty=console, sql=PostgreSQL, dynamodb=DynamoDB)"
            },
            "dynamodb": {
              "type": "object",
              "description": "DynamoDB configuration (when backend=dynamodb)",
              "properties": {
                "tableName": {
                  "type": "string",
                  "description": "DynamoDB table name"
                },
                "ttlDays": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 365,
                  "description": "TTL in days (0 to disable)"
                }
              }
            },
            "sql": {
              "type": "object",
              "description": "SQL (PostgreSQL) configuration (when backend=sql)",
              "properties": {
                "dsn": {
                  "type": "string",
                  "description": "PostgreSQL DSN (prefer existingSecret for production)"
                },
                "existingSecret": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Secret name containing DSN"
                    },
                    "key": {
                      "type": "string",
                      "description": "Key within the Secret"
                    }
                  }
                }
              }
            }
          }
        },
        "selector": {
          "type": "object",
          "description": "Rate limit selector store configuration",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "memory",
                "redis",
                "dynamodb"
              ],
              "description": "Selector store type"
            },
            "redis": {
              "type": "object",
              "description": "Redis configuration (when type=redis)",
              "properties": {
                "address": {
                  "type": "string",
                  "description": "Redis address (host:port)"
                },
                "password": {
                  "type": "string",
                  "description": "Redis password (prefer existingSecret)"
                },
                "db": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15,
                  "description": "Redis database number"
                },
                "tls": {
                  "type": "boolean",
                  "description": "Enable TLS (required for production)"
                },
                "existingSecret": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "dynamodb": {
              "type": "object",
              "description": "DynamoDB configuration (when type=dynamodb)",
              "properties": {
                "tableName": {
                  "type": "string",
                  "description": "DynamoDB table name"
                },
                "ttlMinutes": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1440,
                  "description": "TTL in minutes (0 to disable, recommended: 60-180)"
                }
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "description": "Organization-wide token issuance policy",
          "required": [
            "version",
            "trustPolicyPath",
            "defaultTokenTTL",
            "maxTokenTTL",
            "providers",
            "maxPermissions"
          ],
          "properties": {
            "version": {
              "type": "string",
              "enum": [
                "1.0"
              ],
              "description": "Policy schema version"
            },
            "trustPolicyPath": {
              "type": "string",
              "minLength": 1,
              "description": "Path to trust policy files in repositories ({org} placeholder supported)"
            },
            "defaultTokenTTL": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3600,
              "description": "Default token TTL in seconds (max 3600 per GitHub limit)"
            },
            "maxTokenTTL": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3600,
              "description": "Maximum token TTL in seconds (max 3600 per GitHub limit)"
            },
            "requireExplicitPolicy": {
              "type": "boolean",
              "description": "If true, requests must include policy_name field"
            },
            "githubAPIBaseURL": {
              "type": "string",
              "description": "GitHub API base URL (for GitHub Enterprise Server)"
            },
            "githubRawBaseURL": {
              "type": "string",
              "description": "GitHub raw content base URL (for GitHub Enterprise Server)"
            },
            "providers": {
              "type": "array",
              "minItems": 1,
              "description": "Trusted OIDC identity providers",
              "items": {
                "type": "object",
                "required": [
                  "issuer",
                  "name"
                ],
                "properties": {
                  "issuer": {
                    "type": "string",
                    "format": "uri",
                    "description": "OIDC issuer URL"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Human-readable provider name"
                  },
                  "requiredClaims": {
                    "type": "object",
                    "description": "Claims that must be present and match patterns (claim name to regex pattern)",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "forbiddenClaims": {
                    "type": "object",
                    "description": "Claims that must NOT match patterns (claim name to regex pattern)",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "timeRestrictions": {
                    "type": "object",
                    "description": "Time-based access restrictions",
                    "properties": {
                      "allowedDays": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": [
                            "Monday",
                            "Tuesday",
                            "Wednesday",
                            "Thursday",
                            "Friday",
                            "Saturday",
                            "Sunday"
                          ]
                        }
                      },
                      "allowedHours": {
                        "type": "object",
                        "properties": {
                          "start": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 23
                          },
                          "end": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 23
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "maxPermissions": {
              "type": "object",
              "description": "Organization-wide maximum permissions",
              "minProperties": 1,
              "additionalProperties": {
                "type": "string",
                "enum": [
                  "none",
                  "read",
                  "write"
                ]
              }
            }
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator integration",
      "properties": {
        "secretStore": {
          "type": "object",
          "description": "SecretStore configuration",
          "properties": {
            "create": {
              "type": "boolean",
              "description": "Create a new SecretStore (if false, reference existing)"
            },
            "name": {
              "type": "string",
              "description": "SecretStore name"
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "provider": {
              "type": "object",
              "description": "Secret provider configuration",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "aws",
                    "gcp",
                    "azure",
                    "vault"
                  ],
                  "description": "Provider type"
                },
                "aws": {
                  "type": "object",
                  "properties": {
                    "service": {
                      "type": "string",
                      "enum": [
                        "SecretsManager",
                        "ParameterStore"
                      ]
                    },
                    "region": {
                      "type": "string"
                    }
                  }
                },
                "gcp": {
                  "type": "object",
                  "properties": {
                    "projectID": {
                      "type": "string"
                    },
                    "clusterLocation": {
                      "type": "string"
                    },
                    "clusterName": {
                      "type": "string"
                    }
                  }
                },
                "azure": {
                  "type": "object",
                  "properties": {
                    "vaultUrl": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                },
                "vault": {
                  "type": "object",
                  "properties": {
                    "server": {
                      "type": "string",
                      "format": "uri"
                    },
                    "path": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string",
                      "enum": [
                        "v1",
                        "v2"
                      ]
                    },
                    "mountPath": {
                      "type": "string"
                    },
                    "role": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "description": "Extra environment variables",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "valueFrom": {
            "type": "object"
          }
        }
      }
    },
    "extraEnvFrom": {
      "type": "array",
      "description": "Extra environment variable sources (configMapRef/secretRef)",
      "items": {
        "type": "object",
        "properties": {
          "configMapRef": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "optional": {
                "type": "boolean"
              }
            }
          },
          "secretRef": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "optional": {
                "type": "boolean"
              }
            }
          },
          "prefix": {
            "type": "string"
          }
        }
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Extra volumes to mount",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Extra volume mounts",
      "items": {
        "type": "object",
        "required": [
          "name",
          "mountPath"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "mountPath": {
            "type": "string"
          },
          "readOnly": {
            "type": "boolean"
          },
          "subPath": {
            "type": "string"
          }
        }
      }
    },
    "initContainers": {
      "type": "array",
      "description": "Init containers to run before main container"
    },
    "sidecars": {
      "type": "array",
      "description": "Sidecar containers to run alongside main container"
    }
  }
}
